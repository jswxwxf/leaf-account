<!-- miniprogram/pages/account/crop-popup/index.wxml -->
<van-popup
  show="{{ visible }}"
  custom-style="height: 100%; width: 100%; background-color: #000;"
  position="bottom"
  @close="onClose"
  custom-class="overflow-y-hidden"
>
  <!-- 顶部操作栏 -->
  <view class="fixed top-0 left-0 right-0 p-4 flex justify-between items-center z-10">
    <view class="text-white text-sm">请拖拽边框，裁切掉无关部分</view>
    <view class="flex gap-4">
      <van-button size="small" @click="onClose">取消</van-button>
      <van-button size="small" type="primary" @click="onConfirm">确定</van-button>
    </view>
  </view>
  <view class="h-full flex items-center justify-center p-4 pt-28 pb-16">
    <view class="relative mt-2" style="width: {{imageInfo.width}}px; height: {{imageInfo.height}}px;">
      <image src="{{imagePath}}" class="w-full h-full" mode="aspectFill" @load="onImageLoad"></image>

      <!-- 遮罩层 -->
      <view
        class="absolute pointer-events-none"
        style="left: {{cropBox.left}}px; top: {{cropBox.top}}px; width: {{cropBox.width}}px; height: {{cropBox.height}}px; box-shadow: 0 0 0 1000px rgba(0, 0, 0, 0.5);"
      ></view>

      <!-- 裁剪框 -->
      <view
        class="absolute"
        style="left: {{cropBox.left}}px; top: {{cropBox.top}}px; width: {{cropBox.width}}px; height: {{cropBox.height}}px;"
      >
        <!-- 默认边框 -->
        <view
          wx:if="{{ !activeEdge }}"
          class="absolute inset-0 border-2 border-blue-500 box-border pointer-events-none"
        ></view>
        <!-- 高亮边框 -->
        <view wx:else class="absolute inset-0 border-2 border-green-500 box-border pointer-events-none"></view>

        <!-- 四个边框热区 (透明) -->
        <view
          class="absolute -top-2 left-0 w-full h-4"
          data-edge="top"
          catch:touchstart="onTouchStart"
          catch:touchmove="onTouchMove"
          catch:touchend="onTouchEnd"
        ></view>
        <view
          class="absolute -bottom-2 left-0 w-full h-4"
          data-edge="bottom"
          catch:touchstart="onTouchStart"
          catch:touchmove="onTouchMove"
          catch:touchend="onTouchEnd"
        ></view>
        <view
          class="absolute -left-2 top-0 w-4 h-full"
          data-edge="left"
          catch:touchstart="onTouchStart"
          catch:touchmove="onTouchMove"
          catch:touchend="onTouchEnd"
        ></view>
        <view
          class="absolute -right-2 top-0 w-4 h-full"
          data-edge="right"
          catch:touchstart="onTouchStart"
          catch:touchmove="onTouchMove"
          catch:touchend="onTouchEnd"
        ></view>
      </view>
    </view>
  </view>

</van-popup>
