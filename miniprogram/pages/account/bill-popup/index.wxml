<van-popup
  show="{{ visible }}"
  position="top"
  @close="handleClose"
  overlay="{{false}}"
  close-icon-position="bottom-right"
  custom-style="position: static;"
>
  <view class="h-full w-full bg-neutral-50 px-4 pt-2 flex flex-col max-h-screen border-b border-dashed border-b-slate-400" style="--cell-background-color: #fafafa;">
    <!-- Main Content: Form -->
    <bill-form id="bill-form">
      <van-cell-group border="{{ false }}" custom-class="flex-1 overflow-y-auto bill-popup-cell-group">
        <calendar-field
          label="日期"
          value="{{ bill.datetime }}"
          field="datetime"
          rule="required|past"
          data-field="datetime"
          @change="handleFormChange"
        />
        <category-field
          label="分类"
          value="{{ bill.category }}"
          field="category"
          rule="required"
          data-field="category"
          @change="handleFormChange"
          disabled="{{ isTransferEditing }}"
        />
        <money-field
          value="{{ bill.amount }}"
          field="amount"
          rule="requiredMoney"
          data-field="amount"
          @change="handleFormChange"
        />
        <note-field
          label="备注"
          value="{{ bill.note }}"
          placeholder="请输入备注"
          field="note"
          rule="required|max:20"
          data-field="note"
          @change="handleFormChange"
          disabled="{{ isTransferEditing }}"
        />
        <tags-field
          value="{{ bill.tags }}"
          data-field="tags"
          @change="handleFormChange"
        />
      </van-cell-group>
    </bill-form>

    <!-- Footer -->
    <view class="flex items-center py-4">
      <view>
        <van-button type="primary" size="small" @tap="handleConfirm" custom-class="w-20">确定</van-button>
      </view>
      <view class="flex-1">
        <van-field
          value="{{ searchText }}"
          placeholder="在此输入检索已加载帐单备注"
          @change="updateSearchText"
          clearable
        />
      </view>
      <view class="flex justify-end items-center space-x-6">
        <view class="i-ep-close text-2xl" @tap="handleClose" />
      </view>
    </view>
  </view>
</van-popup>
