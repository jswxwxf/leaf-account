<van-popup
  show="{{ visible }}"
  position="top"
  @close="handleClose"
  overlay="{{false}}"
  close-icon-position="bottom-right"
  custom-style="position: static;"
>
  <view class="h-full w-full bg-white px-4 pt-2 flex flex-col border-b border-solid border-gray-300 max-h-screen">
    <!-- Main Content: Form -->
    <van-cell-group class="flex-1 overflow-y-auto">
      <calendar-field
        label="日期"
        value="{{ bill.datetime }}"
        data-field="datetime"
        @change="handleFormChange"
      />
      <category-field
        label="分类"
        value="{{ bill.category }}"
      />
      <van-field
        label="金额"
        type="digit"
        value="{{ bill.amount }}"
        placeholder="请输入金额"
        data-field="amount"
        @change="handleFormChange"
      />
      <van-field
        label="备注"
        value="{{ bill.note }}"
        placeholder="请输入备注"
        data-field="note"
        @change="handleFormChange"
      />
      <van-field
        label="标签"
        value="{{ bill.tags }}"
        placeholder="请输入标签（多个用逗号隔开）"
        data-field="tags"
        @change="handleFormChange"
      />
    </van-cell-group>

    <!-- Footer -->
    <view class="flex items-center py-4 border-t border-solid border-gray-100">
      <view class="flex-1">
        <van-button type="primary" size="small" @tap="handleConfirm">确定</van-button>
      </view>
      <view class="flex-1 text-center text-sm text-gray-500"></view>
      <view class="flex-1 flex justify-end items-center space-x-6">
        <view class="i-ep-close text-2xl" @tap="handleClose" />
      </view>
    </view>
  </view>
</van-popup>
