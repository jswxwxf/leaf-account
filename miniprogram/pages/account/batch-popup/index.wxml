<van-popup
  show="{{ visible }}"
  position="top"
  @close="handleClose"
  overlay="{{false}}"
  close-icon-position="bottom-right"
  custom-style="position: static;"
>
  <view class="h-full w-full bg-neutral-50 flex flex-col max-h-[60vh] border-b border-dashed border-b-slate-400" style="--cell-background-color: #fafafa">
    <!-- Main Content: make it scrollable -->
    <view wx:if="{{ visible }}" class="flex-1 overflow-y-auto px-1 pt-1">
      <!-- Rows -->
      <view
        wx:for="{{ list }}"
        wx:for-item="bill"
        wx:for-index="rowIndex"
        wx:key="_tempid"
        class="flex mb-[0.4rem] py-1 pl-1 bg-slate-100 items-center {{ bill.deleted ? 'slide-out-right' : '' }} {{ bill.inserted ? 'slide-in-left' : '' }}"
      >
        <view class="pl-1 pr-2">{{ rowIndex + 1 }}</view>
        <bill-form class="bill-form">
          <view class="flex-1 batch-popup-form">
            <!-- Row 1: Date, Category, Amount -->
            <view class="grid grid-cols-3 gap-1">
              <calendar-field
                label=""
                value="{{ bill.datetime }}"
                type="short"
                placeholder="输入日期"
                field="datetime"
                rule="required|past"
                show-error="{{ false }}"
                @change="handleFormChange"
                data-field="datetime"
                data-row-index="{{ rowIndex }}"
              />
              <category-field
                label=""
                value="{{ bill.category }}"
                placeholder="输入分类"
                field="category"
                rule="required"
                show-error="{{ false }}"
                @change="handleFormChange"
                data-field="category"
                data-row-index="{{ rowIndex }}"
              />
              <money-field
                label=""
                value="{{ bill.amount }}"
                placeholder="输入金额"
                field="amount"
                rule="requiredMoney"
                show-error="{{ false }}"
                @change="handleFormChange"
                data-field="amount"
                data-row-index="{{ rowIndex }}"
              />
            </view>
            <!-- Row 2: Note and Tags -->
            <view class="grid grid-cols-5 gap-1 mt-1">
              <note-field
                class="col-span-3"
                label=""
                value="{{ bill.note }}"
                placeholder="输入备注"
                field="note"
                rule="required|max:20"
                show-error="{{ false }}"
                moveable="{{ options.noteMoveable && list.length > 1 }}"
                @change="handleFormChange"
                @position="handlePositionChange"
                data-field="note"
                data-row-index="{{ rowIndex }}"
              />
              <tags-field
                class="col-span-2"
                label=""
                value="{{ bill.tags }}"
                placeholder="输入标签"
                @change="handleFormChange"
                data-field="tags"
                data-row-index="{{ rowIndex }}"
              />
            </view>
          </view>
        </bill-form>
        <view class="w-16 flex flex-col items-center gap-2 space-y-2">
          <van-icon
            name="add-o"
            size="20px"
            @tap="handleAddRow"
            data-row-index="{{ rowIndex }}"
            color="{{ list.length >= 20 ? '#c8c9cc' : '' }}"
          />
          <view
            class="i-ep-copy-document text-[1rem] {{ list.length >= 20 ? 'text-gray-400' : '' }}"
            @tap="handleCopyRow"
            data-row-index="{{ rowIndex }}"
          />
          <van-icon
            name="delete-o"
            size="20px"
            @tap="handleDeleteRow"
            data-row-index="{{ rowIndex }}"
            color="{{ list.length > 1 ? '' : '#c8c9cc' }}"
          />
        </view>
      </view>
    </view>

    <!-- Footer: stays at the bottom, original structure preserved -->
    <view class="flex items-center py-4 border-t border-solid border-gray-100 px-4">
      <view>
        <van-button type="primary" size="small" @tap="handleConfirm" custom-class="w-20">确定</van-button>
      </view>
      <view class="flex-1" />
      <view class="flex justify-end items-center space-x-6">
        <view class="i-ep-close text-2xl" @tap="handleClose" />
      </view>
    </view>
  </view>
</van-popup>
