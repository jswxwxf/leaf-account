<van-popup
  show="{{ visible }}"
  position="top"
  @close="handleClose"
  overlay="{{false}}"
  close-icon-position="bottom-right"
  custom-style="position: static;"
>
  <view class="h-full w-full bg-white px-4 pt-2 flex flex-col border-b border-solid border-gray-300 max-h-screen">
    <!-- Main Content: make it scrollable -->
    <view class="flex-1 overflow-y-auto">
      <!-- Rows -->
      <block wx:for="{{ list }}" wx:for-item="bill" wx:for-index="rowIndex" wx:key="rowIndex">
        <!-- Row 1: Date, Category, Amount -->
        <view class="grid grid-cols-3 gap-2">
          <calendar-field
            label=""
            value="{{ bill.datetime }}"
            type="short"
            placeholder="日期"
            bind:change="handleFormChange"
            data-field="datetime"
            data-row-index="{{ rowIndex }}"
          />
          <category-field
            label=""
            value="{{ bill.category }}"
            placeholder="分类"
            bind:change="handleFormChange"
            data-field="category"
            data-row-index="{{ rowIndex }}"
          />
          <money-field
            label=""
            value="{{ bill.amount }}"
            placeholder="金额"
            bind:change="handleFormChange"
            data-field="amount"
            data-row-index="{{ rowIndex }}"
          />
        </view>
        <!-- Row 2: Note and Tags -->
        <view class="grid grid-cols-5 gap-2 mt-1">
          <van-field
            class="col-span-3"
            label=""
            value="{{ bill.note }}"
            placeholder="备注"
            @change="handleFormChange"
            data-field="note"
            data-row-index="{{ rowIndex }}"
          />
          <tags-field
            class="col-span-2"
            label=""
            value="{{ bill.tags }}"
            placeholder="标签"
            bind:change="handleFormChange"
            data-field="tags"
            data-row-index="{{ rowIndex }}"
          />
        </view>
      </block>
    </view>

    <!-- Footer: stays at the bottom, original structure preserved -->
    <view class="flex items-center py-4 border-t border-solid border-gray-100">
      <view class="flex-1">
        <van-button type="primary" size="small" @tap="handleConfirm">确定</van-button>
      </view>
      <view class="flex-1 text-center text-sm text-gray-500">
        <!-- 提示信息 -->
      </view>
      <view class="flex-1 flex justify-end items-center space-x-6">
        <view class="i-ep-close text-2xl" @tap="handleClose" />
      </view>
    </view>
  </view>
</van-popup>
