<van-popup
  show="{{ visible }}"
  position="top"
  @close="handleClose"
  overlay="{{false}}"
  close-icon-position="bottom-right"
  custom-style="position: static;"
>
  <view class="h-full w-full bg-neutral-50 pt-2 max-h-screen border-b border-dashed border-b-slate-400">
    <!-- Chart Content Goes Here -->
    <view wx:if="{{ visible }}">
      <view wx:if="{{ active === 'chart' }}" class="w-full h-52 px-4 pl-0 block box-border">
        <qiun-data-charts
          reshow="{{ active === 'chart' }}"
          type="line"
          canvas2d
          disable-scroll
          animation="{{ false }}"
          chart-data="{{ chartData }}"
          opts="{{ chartOptions }}"
          ontap
          ontouch
          @getIndex="onChartTap"
        />
      </view>
      <view wx:if="{{ active === 'calendar' }}" class="h-52">
        <bill-calendar
          first-day-of-week="1"
          daily-bills="{{ dailyBills }}"
          month="{{ monthValue }}"
          @month-change="handleMonthChange"
          @tap-bill-day="handleTapBillDay"
        />
      </view>
    </view>

    <!-- Footer -->
    <view class="flex items-center px-4 pl-0 py-4">
      <view class="flex-1">
        <van-tabs
          type="card"
          active="{{ active }}"
          @change="onChange"
          color="#22c55e"
          nav-class="!bg-transparent"
          tab-class="text-xs !py-1"
        >
          <van-tab title="图表" name="chart"></van-tab>
          <van-tab title="日历" name="calendar"></van-tab>
        </van-tabs>
      </view>
      <view wx:if="{{active === 'chart'}}" class="text-xs text-gray-400 text-center flex-1">点击图例可切换</view>
      <view wx:if="{{active === 'calendar'}}" class="text-xs text-gray-400 text-center flex-1">左右滑动可切换月份</view>
      <view class="flex justify-end items-center space-x-6">
        <view class="i-ep-close text-2xl" @tap="handleClose" />
      </view>
    </view>
  </view>
</van-popup>
