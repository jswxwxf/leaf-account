<view class="h-screen bg-gray-100 flex flex-col">
  <account-summary hidden="{{ billPopped }}" @balance-tap="handleReconcile" />

  <bill-popup id="bill-popup" />
  <batch-popup id="batch-popup" />

  <!-- Bill List -->
  <block wx:if="{{ billPopped && imagePath }}">
    <scroll-view scroll-y class="flex-1 overflow-hidden">
      <image src="{{ imagePath }}" class="w-full" mode="widthFix" />
    </scroll-view>
  </block>
  <block wx:else>
    <scroll-view
      scroll-y
      class="flex-1 overflow-hidden"
      lower-threshold="100"
      @scrolltolower="loadMore"
      scroll-top="{{ scrollTop }}"
    >
      <view class="pb-16 pt-2 relative">
        <block wx:for="{{ dailyBills }}" wx:key="_id">
          <bill-group item="{{ item }}" @edit="handleEditBill" @delete="handleDeleteBill" />
        </block>

        <!-- Loading and No More States -->
        <view class="py-4 text-center text-gray-500 text-sm">
          <view wx:if="{{ loading }}">正在加载...</view>
          <view wx:if="{{ !hasMore && dailyBills.length > 0 }}">没有更多了</view>
          <view wx:if="{{ !loading && dailyBills.length === 0 }}">暂无数据</view>
        </view>
      </view>
    </scroll-view>
  </block>

  <!-- Fixed Add Button -->
  <view class="fixed bottom-16 right-4">
    <add-button hidden="{{ billPopped }}" @click="handleAddBill" @select="handleActionSelect" />
  </view>
</view>

<van-toast id="van-toast" />
<van-dialog id="van-dialog" />

<category-helper />
<tags-helper />
<calendar-helper />
<reconcile-popup id="reconcile-popup" />
<alert-popup id="alert-popup" />
