<wxs src="../../../utils/utils.wxs" module="utils" />
<wxs module="tools">
  var isTransferUnlinked = function(bill) {
    if (!bill || !bill.category) return false
    return (bill.category.name === '转账' || bill.category.name === '收转账') && !bill.relatedBill
  }

  var isCopyDisabled = function(bill) {
    if (!bill || !bill.category) return false
    return bill.category.name === '转账' || bill.category.name === '收转账'
  }

  module.exports = {
    isTransferUnlinked: isTransferUnlinked,
    isCopyDisabled: isCopyDisabled
  }
</wxs>

<view class="bg-white shadow-sm mb-2" hidden="{{ bills.length === 0 }}" style="--checkbox-label-margin: 8px">
  <van-cell-group>
    <van-cell>
      <view slot="title" class="flex justify-between items-center whitespace-nowrap">
        <view class="flex items-center {{ utils.isWeekend(item.datetime) ? 'text-orange-500' : 'text-gray-500' }}">
          <van-checkbox
            shape="square"
            icon-size="16px"
            custom-class="{{ batchEditPopped ? 'batch-checkbox' : 'batch-checkbox--hidden' }}"
            value="{{ allChecked }}"
            @change="toggleAll"
          >
            <text class="font-bold text-base">{{ utils.formatDateTime(item.datetime, 'YYYY年MM月DD日') }}</text>
          </van-checkbox>
          <text class="text-sm ml-2">{{ item.day }} {{ item.bills.length }} 笔</text>
        </view>
        <view class="text-xs text-gray-500">
          <text class="mr-4">出 {{ item.expense }}</text>
          <text>入 {{ item.income }}</text>
        </view>
      </view>
    </van-cell>
    <block wx:for="{{ bills }}" wx:key="_id" wx:for-item="bill">
      <van-swipe-cell class="swipe-cell" right-width="{{ 64 * 3 }}" disabled="{{ billPopped || batchEditPopped }}">
        <van-cell custom-class="{{ utils.isToday(bill.createdAt) ? 'bill-item--today' : '' }}">
          <view class="flex items-center">
            <van-checkbox
              value="{{ batchChecked[bill._id] }}"
              shape="square"
              icon-size="16px"
              @change="onBatchCheck"
              custom-class="{{ batchEditPopped ? 'batch-checkbox' : 'batch-checkbox--hidden' }}"
              class="flex-1 text-left min-w-0"
              data-bill="{{bill}}"
            >
              <view @tap.catch="handleCopyNote" data-bill="{{bill}}">
                <view class="text-base text-black">{{ bill.category.name }}</view>
                <view class="text-xs text-gray-500 overflow-hidden van-ellipsis">{{ bill.note }}</view>
              </view>
            </van-checkbox>
            <view wx:if="{{tools.isTransferUnlinked(bill)}}" class="mr-1">
              ⛓‍💥
            </view>
            <view wx:if="{{ bill.tags.length }}" class="flex items-end">
              <block wx:for="{{ bill.tags }}" wx:key="_id" wx:for-item="tag">
                <bill-tag type="{{tag.type}}" custom-class="ml-1">{{tag.name}}</bill-tag>
              </block>
            </view>
            <view class="w-24 text-right font-bold {{ bill.amount > 0 ? 'text-green-500' : 'text-gray-800' }}">
              {{ utils.formatMoney(bill.amount) }}
            </view>
          </view>
        </van-cell>
        <view slot="right" class="van-swipe-cell__right flex h-full">
          <view
            class="h-full w-[64px] flex items-center justify-center text-white text-sm bg-blue-400  {{ tools.isCopyDisabled(bill) ? 'grayscale' : '' }}"
            @tap="handleCopy"
            data-bill="{{bill}}"
            data-disabled="{{tools.isCopyDisabled(bill)}}"
          >
            复制
          </view>
          <view
            class="h-full w-[64px] flex items-center justify-center text-white text-sm bg-green-500"
            @tap="handleEdit"
            data-bill="{{bill}}"
          >
            编辑
          </view>
          <view
            class="h-full w-[64px] flex items-center justify-center text-white text-sm bg-red-500"
            @tap="handleDelete"
            data-bill="{{bill}}"
          >
            删除
          </view>
        </view>
      </van-swipe-cell>
    </block>
  </van-cell-group>
</view>
