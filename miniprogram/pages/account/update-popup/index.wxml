<van-popup
  show="{{ visible }}"
  position="top"
  @close="handleClose"
  overlay="{{false}}"
  close-icon-position="bottom-right"
  custom-style="position: static;"
>
  <view
    class="h-full w-full bg-neutral-50 flex flex-col max-h-[60vh] border-b border-dashed border-b-slate-400"
    style="--cell-background-color: #fafafa"
  >
    <bill-form id="update-form">
      <van-cell-group border="{{ false }}" custom-class="flex-1 update-popup-cell-group pt-1 pl-4">
        <view class="flex items-center">
          <van-checkbox
            value="{{ updateField.datetime }}"
            shape="square"
            icon-size="16px"
            checked-color="#07c160"
            @change="handleFieldChange"
            data-field="datetime"
            disabled="{{ hasTransferUpdating }}"
          />
          <calendar-field
            label="更新日期"
            value="{{ updateData.datetime }}"
            placeholder="{{ hasTransferUpdating  ? '有转账不支持批量修改' : '请选择日期' }}"
            data-field="datetime"
            disabled="{{ !updateField.datetime  }}"
            @change="handleFormChange"
          />
        </view>
        <view class="flex items-center">
          <van-checkbox
            value="{{ updateField.category }}"
            shape="square"
            icon-size="16px"
            checked-color="#07c160"
            @change="handleFieldChange"
            data-field="category"
            disabled="{{ hasTransferUpdating || hasConflictCategory }}"
          />
          <category-field
            label="更新分类"
            value="{{ updateData.category }}"
            placeholder="{{ hasTransferUpdating  ? '有转账不支持批量修改' : ( hasConflictCategory ? '分类不一致无法修改' : '请选择分类' ) }}"
            data-field="category"
            disabled="{{ !updateField.category  }}"
            @change="handleFormChange"
            options="{{ categoryOptions }}"
          />
        </view>
        <view class="flex items-center">
          <van-checkbox
            value="{{ updateField.amount }}"
            shape="square"
            icon-size="16px"
            checked-color="#07c160"
            @change="handleFieldChange"
            data-field="amount"
            disabled="{{ hasTransferUpdating || hasConflictCategory }}"
          />
          <money-field
            label="更新金额"
            value="{{ updateData.amount }}"
            placeholder="{{ hasTransferUpdating  ? '有转账不支持批量修改' : ( hasConflictCategory ? '分类不一致无法修改' : '请选择分类' ) }}"
            data-field="amount"
            disabled="{{ !updateField.amount  }}"
            @change="handleFormChange"
          />
        </view>
        <view class="flex items-center">
          <van-checkbox
            value="{{ updateField.note }}"
            shape="square"
            icon-size="16px"
            checked-color="#07c160"
            @change="handleFieldChange"
            data-field="note"
            disabled="{{ hasTransferUpdating }}"
          />
          <note-field
            label="更新备注"
            value="{{ updateData.note }}"
            placeholder="{{ hasTransferUpdating  ? '有转账不支持批量修改' : '请输入备注' }}"
            data-field="note"
            disabled="{{ !updateField.note  }}"
            @change="handleFormChange"
          />
        </view>
        <view class="flex items-center">
          <van-checkbox
            value="{{ updateField.tags }}"
            shape="square"
            icon-size="16px"
            checked-color="#07c160"
            @change="handleFieldChange"
            data-field="tags"
            disabled="{{ hasTransferUpdating }}"
          />
          <tags-field
            label="更新标签"
            value="{{ updateData.tags }}"
            placeholder="{{ hasTransferUpdating  ? '有转账不支持批量修改' : '请选择标签' }}"
            data-field="tags"
            disabled="{{ !updateField.tags  }}"
            @change="handleFormChange"
            class="flex-1 pr-5"
          />
        </view>
      </van-cell-group>
    </bill-form>

    <!-- Footer: stays at the bottom, original structure preserved -->
    <view class="flex items-center py-4 border-t border-solid border-gray-100 px-4">
      <view>
        <van-checkbox value="{{ batchAllChecked }}" shape="square" icon-size="16px" @change="batchCheckAll" />
      </view>
      <view class="flex gap-1">
        <van-button type="primary" size="small" @tap="handleConfirm" custom-class="w-20">确定</van-button>
        <van-button type="danger" size="small" @tap="handleDelete" custom-class="w-20">删除</van-button>
      </view>
      <view class="flex-1" />
      <view class="flex justify-end items-center space-x-6">
        <view class="i-ep-close text-2xl" @tap="handleClose" />
      </view>
    </view>
  </view>
</van-popup>
<van-dialog id="van-dialog" />
