<wxs src="../../utils/utils.wxs" module="utils" />
<wxs module="tools">
  var formatMonth = function(month) {
    var year = getDate().getFullYear()
    if (!month) return year + '全年'
    return year + '年' + month + '月'
  }

  var joinAccountTitles = function(accounts) {
    if (!accounts || accounts.length === 0) {
      return '';
    }
    return accounts.map(function(acc) {
      return acc.title;
    }).join(',');
  }

  module.exports = {
    formatMonth: formatMonth,
    joinAccountTitles: joinAccountTitles,
  }
</wxs>

<view class="pb-12">
  <view class="p-4 bg-white shadow-md mb-4">
    <view class="grid grid-cols-3 gap-4 text-center">
      <view>
        <view class="text-sm text-gray-500">总支出</view>
        <view class="text-lg font-bold text-gray-800">{{ utils.formatMoney(totals.expense) }}</view>
      </view>
      <view>
        <view class="text-sm text-gray-500">总收入</view>
        <view class="text-lg font-bold text-green-600">{{ utils.formatMoney(totals.income) }}</view>
      </view>
      <view>
        <view class="text-sm text-gray-500">总结余</view>
        <view class="text-lg font-bold text-blue-600">{{ utils.formatMoney(totals.balance) }}</view>
      </view>
    </view>
  </view>

  <master-chart />

  <view class="flex justify-between items-center px-4 pt-4 pb-0 gap-2">
    <view class="flex-1 py-1 px-2 text-sm leading-5 select-none overflow-hidden whitespace-nowrap text-ellipsis" style="box-shadow: 0 0 5px rgba(0, 0, 0, 0.2)">
      <text class="text-sm text-slate-400">账本：</text>
      <text class="text-base font-bold text-slate-700">{{ tools.joinAccountTitles(selectedAccounts) }}</text>
    </view>
    <van-button
      type="primary"
      size="small"
      plain
      @click="onSelectAccounts"
      disabled="{{ availableAccounts.length === 1 }}"
    >
      选择账本
    </van-button>
  </view>

  <view class="px-4 pt-4 flex items-center justify-between">
    <view>
      <text class="text-xs">维度：</text>
      <check-group size="small" value="{{ dimension }}" @change="onDimensionChange">
        <check-group-item title="分类" value="category" />
        <check-group-item title="月份" value="month" />
      </check-group>
    </view>
    <view class="flex justify-between items-center gap-2">
      <view class="flex-1 px-2 py-1 text-sm leading-5 select-none" style="box-shadow: 0 0 5px rgba(0, 0, 0, 0.2)">
        <text class="text-sm text-slate-400">月份：</text>
        <text class="text-sm font-bold text-slate-700">{{ tools.formatMonth(monthValue) }}</text>
      </view>
      <van-button
        type="primary"
        size="small"
        plain
        @click="onMonthChange"
      >
        切换月份
      </van-button>
    </view>
  </view>

  <view class="p-4 pt-2 flex items-center justify-between">
    <view>
      <text class="text-xs">包含：</text>
      <check-group size="small" value="{{ checkedValue }}" @change="onCheckedChange" multiple>
        <check-group-item title="不计入" value="exclude" />
        <check-group-item title="转账" value="transfer" />
        <check-group-item title="余额" value="balance" />
      </check-group>
    </view>
    <check-group size="small" value="{{ typeValue }}" @change="onTypeChange">
      <check-group-item title="全部" value="all" />
      <check-group-item title="支出" value="20" />
      <check-group-item title="收入" value="10" />
    </check-group>
  </view>

  <pie-chart />
  <view class="h-4" />
  <group-chart />
</view>

<accounts-helper />
<month-helper />
