<view class="w-full h-52 px-4 pl-0 block box-border">
  <block wx:if="{{ chartReady }}">
    <qiun-data-charts
      type="column"
      canvas2d
      disable-scroll
      animation="{{ false }}"
      chart-data="{{ chartData }}"
      opts="{{ chartOptions }}"
      ontap
      ontouch
      @getIndex="onChartTap"
    />
  </block>
</view>
