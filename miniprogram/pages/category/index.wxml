<view class="flex flex-col h-screen">
  <!-- Manual Tabs Header -->
  <van-tabs active="{{ activeTab }}" @change="onTabChange" color="#34D399" class="flex-shrink-0 mb-4">
    <van-tab title="支出" name="20" />
    <van-tab title="入账" name="10" />
  </van-tabs>

  <!-- Expense Content -->
  <view class="flex-grow overflow-auto px-4 pb-4" wx:if="{{ activeTab === '20' }}">
    <view wx:if="{{ categories.expense.length === 0 }}" class="text-center text-gray-500 py-10">
      暂无支出分类，快来添加吧~
    </view>
    <block wx:else>
      <view class="grid grid-cols-3 gap-2">
        <block wx:for="{{ categories.expense }}" wx:key="_id">
          <category-box category="{{ item }}" @edit="handleEdit" @delete="handleDelete" />
        </block>
      </view>
    </block>
  </view>

  <!-- Income Content -->
  <view class="flex-grow overflow-auto px-4 pb-4" wx:if="{{ activeTab === '10' }}">
    <block wx:if="{{ categories.income.length > 0 }}">
      <view class="grid grid-cols-3 gap-2">
        <block wx:for="{{ categories.income }}" wx:key="_id">
          <category-box category="{{ item }}" @edit="handleEdit" @delete="handleDelete" />
        </block>
      </view>
    </block>
    <view wx:else class="text-center text-gray-500 py-10">
      暂无收入分类，快来添加吧~
    </view>
  </view>

  <!-- Footer -->
  <view class="flex-shrink-0 p-4 border-t border-gray-200 pb-safe">
    <category-editor
      value="{{ newCategory }}"
      data-field="name"
      @change="handleFormChange"
      @submit="handleAdd"
    />
  </view>
</view>

<van-dialog id="van-dialog" />
<category-popup id="category-popup" />
