<view class="flex flex-col h-screen">
  <!-- Content -->
  <view class="flex-grow overflow-auto p-4">
    <view wx:if="{{ tags.length === 0 }}" class="text-center text-gray-500 py-10">
      暂无标签，快来添加吧~
    </view>
    <block wx:else>
      <view class="grid grid-cols-3 gap-2">
        <block wx:for="{{ tags }}" wx:key="_id">
          <tag-box tag="{{ item }}" @edit="handleEdit" @delete="handleDelete" />
        </block>
      </view>
    </block>
  </view>

  <!-- Footer -->
  <view class="flex-shrink-0 p-4 border-t border-{{theNewTag.type}} bg-white pb-safe">
    <tag-editor
      value="{{ theNewTag }}"
      @change="handleFormChange"
      @submit="handleAdd"
    />
  </view>
</view>

<van-dialog id="van-dialog" />
<tag-popup id="tag-popup" />
