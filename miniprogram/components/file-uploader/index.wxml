<view
  class="flex h-11 w-full cursor-pointer items-center justify-center rounded-lg border border-dashed border-gray-300 bg-gray-50 text-center hover:border-blue-500"
  @tap="onTap"
>
  <slot wx:if="{{!fileName}}"></slot>
  <view wx:else class="break-all px-2 text-sm text-gray-600">{{fileName}}</view>
</view>
