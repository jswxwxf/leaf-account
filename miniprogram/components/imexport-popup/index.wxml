<van-popup show="{{ visible }}" @close="onClose" closeable>
  <view class="p-4 h-full flex flex-col">
    <view class="mb-4">
      <view class="flex-1">{{ mode === 'import' ? '导入' : '导出' }} {{ currentAccount.title }} 帐单</view>
    </view>
    <view class="flex items-center justify-between gap-2">
      <block wx:if="{{ mode === 'export' }}">
        <view class="flex-1 text-sm text-gray-500 w-48 text-center">
          {{ yearRange.start }}<block wx:if="{{ yearRange.start !== yearRange.end }}"> - {{ yearRange.end }}</block> 所有帐单
        </view>
      </block>
      <block wx:else>
        <file-uploader id="file-uploader" class="w-48" extension="{{['xls', 'xlsx']}}" @change="onFileChange" disabled="{{isTaskRunning}}">
          <view class="flex items-center justify-center h-full text-gray-400">
            <van-icon name="plus" size="20px" />
            <view class=" ml-2">点击选择文件</view>
          </view>
        </file-uploader>
      </block>
      <van-button type="primary" custom-class="w-20" @tap="onTap" disabled="{{ isTaskRunning }}">{{ mode === 'import' ? '导入' : '导出' }}</van-button>
    </view>
    <view wx:if="{{ isTaskRunning }}" class="mt-4 text-center">
      <van-progress percentage="{{ taskProgress }}" show-pivot="{{ false }}" class="my-2" />
      <view class="text-sm text-gray-500 mt-2">{{ taskStatusText }}</view>
    </view>
  </view>
</van-popup>

<van-toast id="van-toast" />
