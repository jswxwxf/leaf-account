<view class="inline-flex overflow-hidden border border-gray-200 bg-white">
  <slot></slot>
  <view class="divider w-px h-5 self-center bg-gray-200"></view>
  <view class="dropdown-action px-2 flex bg-green-500 text-white items-center h-full" @tap.stop="onToggleActionSheet">
    <van-icon name="arrow-up" />
  </view>
</view>

<van-action-sheet
  show="{{ showActionSheet }}"
  actions="{{ actions }}"
  @close="onCloseActionSheet"
  @select="onSelect"
  cancel-text="取消"
  safe-area-inset-bottom="{{ false }}"
/>
