<van-popup show="{{ visible }}" position="bottom" closeable safe-area-inset-bottom="{{false}}" bind:close="handleClose">
  <view class="p-4">
    <view class="text-lg font-bold text-center mb-4">选择分类</view>

    <!-- 分类列表 -->
    <view class="grid grid-cols-3 gap-3 mb-4 category-list">
      <van-button
        wx:for="{{ categories }}"
        wx:key="index"
        plain
        custom-class="flex items-center justify-center p-2 text-sm w-full {{item.type === '20' ? 'expense-button' : 'income-button'}}"
        @tap="handleSelect"
        data-name="{{ item.name }}"
      >
        {{ item.name }}
      </van-button>
    </view>

    <!-- 新分类输入 -->
    <van-field
      value="{{ category.name }}"
      placeholder="新分类，点击右边图标切换类型"
      border="{{ false }}"
      use-button-slot
      @change="onCategoryChange"
      custom-class="flex-1 input-wrapper input-wrapper--type-{{category.type}}"
    >
      <view slot="right-icon">
        <view wx:if="{{category.type === '20'}}" class="flex items-center gap-1" @tap="toggleCategoryType">
          <van-icon name="cash-back-record-o" color="#ee0a24" size="20px" />支
        </view>
        <view wx:if="{{category.type === '10'}}" class="flex items-center gap-1" @tap="toggleCategoryType">
          <van-icon name="gold-coin-o" color="#07c160" size="20px" />收
        </view>
      </view>
      <van-button slot="button" size="small" type="primary" bind:click="handleAddNew" disabled="{{ !category.name }}">
        确定
      </van-button>
    </van-field>
  </view>
</van-popup>
