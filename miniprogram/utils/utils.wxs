/**
 * WXS 安全的 JSON.stringify 版本
 * @param {any} jsonData - 需要序列化的 JSON 对象
 * @returns {string} - 序列化后的 JSON 字符串
 */
function stringify(jsonData) {
  return JSON.stringify(jsonData)
}

/**
 * 格式化金额，添加千分位逗号
 * @param {number|string} value - 需要格式化的值
 * @param {number} [digits=2] - 保留的小数位数
 * @returns {string} - 格式化后的金额字符串
 */
function formatMoney(value, digits) {
  // 设置默认值
  if (digits === undefined) {
    digits = 2
  }

  if (value === undefined || value === null || value === '') {
    return ''
  }

  // 将值转换为数字
  var number = parseFloat(value)

  // 处理非数字情况
  if (isNaN(number)) {
    return value.toString()
  }

  // 检查是否为负数
  var isNegative = number < 0
  if (isNegative) {
    number = -number
  }

  // 四舍五入并保留指定小数位数
  number = number.toFixed(digits)

  // 分割整数部分和小数部分
  var parts = number.split('.')
  var integerPart = parts[0]
  var decimalPart = parts.length > 1 ? '.' + parts[1] : ''

  // 添加千分位分隔符
  var formatted = ''
  var count = 0
  var i

  for (i = integerPart.length - 1; i >= 0; i--) {
    formatted = integerPart[i] + formatted
    count++

    // 每四位添加一个逗号，但最后一位后面不添加
    if (count % 3 === 0 && i > 0) {
      formatted = ',' + formatted
    }
  }

  // 如果原始数字是负数，则在结果前添加负号
  if (isNegative) {
    formatted = '-' + formatted
  }

  return formatted + decimalPart
}

/**
 * 从格式化的金额字符串中解析出原始数字
 * @param {string} formattedValue - 格式化的金额字符串
 * @returns {number} - 解析后的数字
 */
function parseMoney(formattedValue) {
  if (typeof formattedValue !== 'string') {
    return formattedValue
  }

  // 不使用正则表达式，改用循环移除逗号
  var cleaned = ''
  var j

  for (j = 0; j < formattedValue.length; j++) {
    var char = formattedValue.charAt(j)
    if (char !== ',') {
      cleaned += char
    }
  }

  return parseFloat(cleaned)
}

// 补零函数
function padZero(num) {
  return num < 10 ? '0' + num : num
}

/**
 * 格式化日期（WXS兼容版）
 * @param {Date|number|string} date - 支持日期对象/时间戳/字符串(自动处理ISO格式)
 * @param {string} [format='YYYY.MM.DD'] - 格式模板
 * @returns {string} 格式化后的日期字符串
 */
function formatDateTime(date, format) {
  if (!date) return ''
  format = format || 'YYYY.MM.DD'

  // 处理不同格式的日期输入
  var d = null
  if (typeof date === 'string') {
    // 使用getRegExp处理ISO格式和普通日期字符串
    var formattedStr = date.replace(getRegExp('T', 'g'), ' ').replace(getRegExp('-', 'g'), '/')
    // 去掉毫秒和'Z'
    var dotIndex = formattedStr.indexOf('.')
    if (dotIndex > -1) {
      formattedStr = formattedStr.slice(0, dotIndex)
    }
    // 兼容Z结尾的情况
    formattedStr = formattedStr.replace(getRegExp('Z', 'gi'), '')
    // WXS 中 getDate 对 'YYYY/MM/DD' 格式的字符串兼容性最好
    d = getDate(formattedStr)
  } else if (typeof date === 'number') {
    // 确保时间戳是整数
    d = getDate(parseInt(date, 10))
  } else if (date.constructor.name === 'Date') {
    // 使用更可靠的 WXS 类型检查方式
    d = getDate(date.getTime())
  } else {
    return ''
  }

  if (isNaN(d.getTime())) return ''

  // 获取日期组件
  var year = d.getFullYear()
  var month = d.getMonth() + 1
  var day = d.getDate()
  var hours = d.getHours()
  var minutes = d.getMinutes()
  var seconds = d.getSeconds()

  // 使用getRegExp进行格式化替换
  return format.replace(getRegExp('YYYY|YY|MM|M|DD|D|HH|H|mm|m|SS|S', 'g'), function (match) {
    switch (match) {
      case 'YYYY':
        return year
      case 'YY':
        return ('' + year).slice(-2)
      case 'MM':
        return padZero(month)
      case 'M':
        return month
      case 'DD':
        return padZero(day)
      case 'D':
        return day
      case 'HH':
        return padZero(hours)
      case 'H':
        return hours
      case 'mm':
        return padZero(minutes)
      case 'm':
        return minutes
      case 'SS':
        return padZero(seconds)
      case 'S':
        return seconds
      default:
        return match
    }
  })
}

/**
 * 获取日期是星期几，或者返回'今天'/'昨天'
 * @param {number} timestamp - 必须是时间戳数字
 * @returns {string} - '今天', '昨天', 或 '星期X'
 */
function getDayOfWeek(timestamp) {
  if (!timestamp) return ''
  var date = getDate(parseInt(timestamp, 10))
  if (isNaN(date.getTime())) return ''

  var today = getDate()
  var yesterday = getDate(today.getTime() - 24 * 60 * 60 * 1000)

  // 比较年、月、日
  if (
    date.getFullYear() === today.getFullYear() &&
    date.getMonth() === today.getMonth() &&
    date.getDate() === today.getDate()
  ) {
    return '今天'
  }

  if (
    date.getFullYear() === yesterday.getFullYear() &&
    date.getMonth() === yesterday.getMonth() &&
    date.getDate() === yesterday.getDate()
  ) {
    return '昨天'
  }

  var weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六']
  return weekdays[date.getDay()]
}

/**
 * 判断一个日期是否为周末 (周六或周日)
 * @param {number} timestamp - 必须是时间戳数字
 * @returns {boolean} - 如果是周末则返回 true, 否则返回 false
 */
function isWeekend(timestamp) {
  if (!timestamp) return false
  var date = getDate(parseInt(timestamp, 10))
  if (isNaN(date.getTime())) return false

  var day = date.getDay()
  return day === 0 || day === 6 // 0 是周日, 6 是周六
}

/**
 * 判断一个日期是否为今天
 * @param {number} timestamp - 必须是时间戳数字
 * @returns {boolean} - 如果是今天则返回 true, 否则返回 false
 */
function isToday(timestamp) {
  if (!timestamp) return false
  var date = getDate(parseInt(timestamp, 10))
  if (isNaN(date.getTime())) return false

  var today = getDate()

  return (
    date.getFullYear() === today.getFullYear() &&
    date.getMonth() === today.getMonth() &&
    date.getDate() === today.getDate()
  )
}

module.exports = {
  stringify: stringify,
  formatMoney: formatMoney,
  parseMoney: parseMoney,
  formatDateTime: formatDateTime,
  getDayOfWeek: getDayOfWeek,
  isWeekend: isWeekend,
  isToday: isToday,
}
