{
  "mcpServers": {
    "task-master-ai": {
      "command": "npx",
      "args": [
        "-y",
        "--package=task-master-ai",
        "task-master-ai"
      ],
      "env": {},
      "disabled": true,
      "alwaysAllow": []
    },
    "cloudbase": {
      "command": "npx",
      "args": [
        "@cloudbase/cloudbase-mcp@latest"
      ]
    },
    "Astro docs": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.docs.astro.build/mcp"]
    }
  }
}
